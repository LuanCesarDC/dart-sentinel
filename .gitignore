
# Dart tool cache (snapshots, package_config, etc.)
.dart_tool/

# Dart Sentinel analysis cache (generated per-project)
.dart_sentinel/

# Compiled Dart kernel files
*.dill

# Pub dependency lock (library packages should not lock deps)
pubspec.lock

# OS files
.DS_Store
Thumbs.db

# IDE (keep .vscode/mcp.json for MCP sharing, ignore the rest)
.idea/
*.iml

# Coverage & test output
coverage/
.test_runner/

# Build artifacts
build/
doc/api/

# vscode_extension artifacts (handled by its own .gitignore)
vscode_extension/out/
vscode_extension/node_modules/
vscode_extension/*.vsix